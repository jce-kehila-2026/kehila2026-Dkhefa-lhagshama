// Firestore Security Rules — UC-05 Admin Approval gating added.
//
// Writes always go through the Express backend (Admin SDK bypasses these rules).
// The client SDK is read-only: public sees only status=approved; admins see all.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // ── /requests — UC-01 ────────────────────────────────────────────────
    // BIG PICTURE: a request document is the most PII-dense record in the
    // system. Besides the beneficiary's own data it accumulates STAFF-ONLY
    // fields over its lifecycle: internal admin `notes`, the `claims` of every
    // interested volunteer (their identity + a private note), `dropReports`
    // (names + free-text reasons of volunteers who abandoned the case), and the
    // internal `handler`/`assignedVolunteerId`. The Express API
    // (GET /api/requests/:id, /mine) strips all of these before returning a
    // request to its owner — but Firestore rules CANNOT do field-level
    // projection: `allow read` returns the WHOLE raw document.
    //
    // SECURITY FIX (audit CRITICAL): the previous rule also let the OWNER read
    // their own request directly via the client SDK
    // (`resource.data.beneficiaryId == request.auth.uid`). That bypassed the
    // API's redaction entirely — a beneficiary could open the browser console
    // and `getDoc(doc(db,'requests', myId))` to read the internal staff notes
    // and other volunteers' PII on their own case. We verified NO frontend code
    // reads /requests via the client SDK (all reads go through the redacting
    // Express endpoints), so we drop the owner grant and make direct client
    // reads ADMIN-ONLY. Beneficiaries/staff are unaffected — they read through
    // the API, which is the real, field-aware security boundary.
    // (Takes effect on the next `firebase deploy --only firestore:rules`.)
    match /requests/{requestId} {
      allow read: if isAdmin();
      // Note 6/8: status, referral and archived are lifecycle fields written
      // ONLY through Express (Admin SDK) — done/status/refer/archive endpoints.
      // No client write carve-out: the client SDK never mutates a request.
      allow create, update, delete: if false;
    }

    // ── /users — profile collection (#63) ───────────────────────────────
    // Owner reads own profile; admin reads all. Writes are server-only:
    // GET/PATCH /api/users/me go through Express (Admin SDK bypasses rules)
    // and lazy-create on register. The client never writes here directly —
    // this prevents role/email self-escalation.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // Note 11: a user may set ONLY their own photoURL (a Storage path) on
      // their own profile doc. Every other field stays server-only so the
      // role/email self-escalation guard is preserved. The backend
      // (POST /api/profile/avatar) does this via the Admin SDK in practice;
      // this rule is the defense-in-depth grant for a direct client write of
      // just photoURL. Any update that touches a field other than photoURL is
      // denied here and must go through Express.
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoURL'])
        && request.resource.data.photoURL is string;

      allow create, delete: if false;
    }

    // ── /requestEvents — request timeline (#65) ──────────────────────────
    // Append-only audit trail of a request's lifecycle. Volunteers and admins
    // see every event; the owning beneficiary sees only events flagged
    // visibility == 'all' (internal notes stay hidden). Writes are server-only
    // via writeRequestEvent() (Admin SDK).
    match /requestEvents/{eventId} {
      // F3: mirror GET /api/requests/:id/events. Admins and the assigned
      // handler of the parent request see all events (including internal
      // notes); the owning beneficiary sees only visibility=='all'. Previously
      // ANY volunteer could read every event on every request (incl. internal
      // admin notes) via the client SDK, bypassing the stricter route.
      allow read: if isSignedIn() && (
        isAdmin()
        || get(/databases/$(database)/documents/requests/$(resource.data.requestId)).data.handler == request.auth.uid
        || (
          resource.data.visibility == 'all'
          && get(/databases/$(database)/documents/requests/$(resource.data.requestId)).data.beneficiaryId == request.auth.uid
        )
      );
      allow create, update, delete: if false;
    }

    // ── /chats — UC-04 ───────────────────────────────────────────────────
    // Read allowed if the caller's uid is in participants[], or for admins
    // (read-only oversight — admins post only after joining as a participant
    // via the Express participant endpoint). Writes are server-only
    // (Express + Admin SDK). Mitigates wiki Risk-#5 (Chat Abuse).
    match /chats/{chatId} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.participants
        || isAdmin()
      );
      allow create, update, delete: if false;
    }

    // ── /messages — UC-04 ────────────────────────────────────────────────
    // A message is readable if the caller participates in its parent chat,
    // or by an admin (same oversight carve-out as /chats).
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        request.auth.uid in get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data.participants
        || isAdmin()
      );
      allow create, update, delete: if false;
    }

    // ── /auditLogs — every server-trusted write is logged ────────────────
    // Admin-only read; never client-writable.
    match /auditLogs/{logId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── /answers — UC-02 community answers catalog ───────────────────────
    // Public reads approved entries; admins see all. Owners may edit only
    // while still pending. Create/delete are server-only.
    match /answers/{answerId} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      // Owner may edit only content fields while still pending. The field
      // allowlist (hasOnly) blocks self-inflating prominence/social-proof
      // (rating/reviews/featured) or flipping status/ownerId — those move only
      // via the Admin SDK (server). Anything not listed denies the whole write.
      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'pending'
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title', 'body', 'category', 'region', 'audience', 'phone', 'email',
          'sourceName', 'sourceUrl', 'updatedAt'
        ]);
      allow create, delete: if false;
    }

    // ── /businesses — UC-03 community business directory ─────────────────
    match /businesses/{businessId} {
      allow read: if resource.data.status == 'approved' || isAdmin();
      // Owner may edit only content fields while still pending. The field
      // allowlist (hasOnly) plus the explicit equality asserts below block an
      // owner from self-inflating rating/reviews or granting themselves the
      // 'featured' badge on the public directory — those are server-only.
      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'pending'
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name', 'ownerName', 'phone', 'category', 'city', 'description',
          'website', 'tags', 'updatedAt'
        ])
        && request.resource.data.rating == resource.data.rating
        && request.resource.data.reviews == resource.data.reviews
        && request.resource.data.featured == resource.data.featured;
      allow create, delete: if false;
    }

    // (Removed the dead /organizations rules block: partner organizations live
    //  in the `answers` collection split by orgType — nothing reads or writes a
    //  separate `organizations` collection. Takes effect on the next rules deploy.)

    // ── /categories — admin-managed request taxonomy ──────────────────────
    // Public read: pickers and label resolution need the bilingual
    // { nameHe, nameEn } docs, archived ones included (old requests keep
    // their raw keys and still resolve labels). All mutations go through
    // /api/admin/categories (Express + Admin SDK) — never the client.
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // ── /ratings — UC experience ratings (#80) ──────────────────────────────
    // One rating per request (doc id == requestId). The owning beneficiary can
    // read their own rating; admins read all. Writes are server-only: POST
    // /api/ratings goes through Express (Admin SDK) which enforces that only the
    // request's beneficiary may rate, and only when the request is resolved.
    match /ratings/{ratingId} {
      allow read: if isSignedIn() && (
        resource.data.beneficiaryId == request.auth.uid
        || isAdmin()
      );
      allow create, update, delete: if false;
    }

    // ── /volunteers — volunteer profile, rating aggregate + roster (#80, #73) ─
    // F6: single source of truth for the /volunteers collection (previously
    // declared in two identical match blocks). Holds both the rating aggregate
    // (#80, maintained by the ratings endpoint) and the approved-roster fields
    // (#73, set by the admin approve/deactivate endpoints). The volunteer reads
    // their own doc; admins read all. All writes are server-only (Admin SDK).
    match /volunteers/{volunteerId} {
      allow read: if isSignedIn() && (
        request.auth.uid == volunteerId
        || isAdmin()
      );
      allow create, update, delete: if false;
    }

    // ── /volunteerApplications — Stream 3 volunteer signup (#70) ────────────
    // The applicant can read their own application; admins can read all.
    // Client never writes here — Express + Admin SDK handle all mutations.
    match /volunteerApplications/{appId} {
      allow read: if isSignedIn() && (
        resource.data.uid == request.auth.uid
        || isAdmin()
      );
      allow create, update, delete: if false;
    }

    // ── /counters — server-only sequence counters (WS-3) ────────────────────
    // Holds counters/requests.next, used ONLY by the Admin SDK (POST
    // /api/requests + backfillDisplayId.ts) to allocate friendly REQ-#### ids.
    // No client ever reads or writes it — deny everything explicitly (the
    // catch-all would also cover this, but an explicit rule documents intent
    // and gives the rules suite a stable target).
    match /counters/{counterId} {
      allow read, write: if false;
    }

    // Catch-all: deny everything not explicitly allowed above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

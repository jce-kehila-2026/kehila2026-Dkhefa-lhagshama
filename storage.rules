// Firebase Storage Security Rules.
//
// UC-01-b: any signed-in user may upload to `requests/{requestId}/{filename}`
// subject to size (≤10MB) and MIME (PDF / JPEG / PNG / DOCX) limits. Reads
// require either ownership of the matching Firestore request doc or the
// admin role custom claim.
//
// #84 — hardened: content-type allowlist enforced server-side in Storage rules;
//         anonymous writes (request.auth == null) are explicitly denied.

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── /requests/{requestId}/{filename} — UC-01 attachments ──────────
    match /requests/{requestId}/{filename} {
      // Read: must be signed in, and either own the matching request doc
      // or be an admin. The request doc lookup uses the Firestore-bridge
      // function available in Storage rules.
      allow read: if request.auth != null
                  && (
                       firestore.get(/databases/(default)/documents/requests/$(requestId)).data.beneficiaryId == request.auth.uid
                       || request.auth.token.role == 'admin'
                     );

      // Write: signed-in, verified-email users only (#84 / #86).
      //  - Must not be anonymous (request.auth != null already excludes
      //    anonymous SDK writes, but the explicit email_verified check
      //    further tightens the gate).
      //  - Size: ≤ 10 MB.
      //  - Content-type: PDF, JPEG, PNG, or DOCX only.
      //
      // NOTE: The Firestore request doc may not exist yet at upload time
      //       (we upload before POST /api/requests creates it), so we
      //       cannot gate writes on doc ownership.
      allow write: if request.auth != null
                   && request.auth.token.email_verified == true
                   && request.resource.size <= 10 * 1024 * 1024
                   && request.resource.contentType in [
                        'image/jpeg',
                        'image/png',
                        'application/pdf',
                        'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
                      ];
    }

    // ── /avatars/{uid}/** — Note 11 volunteer/profile photos ──────────────
    // Profile photos are PII. Client READS are denied — the backend mints
    // short-lived signed URLs (GET /api/chats/:id/participants,
    // POST /api/profile/avatar) so only authorized callers ever get a link.
    //
    // Write: only the owner (request.auth.uid == uid), and only an image
    // (jpeg/png/webp) within the 5 MB cap. In practice the upload goes through
    // POST /api/profile/avatar (Admin SDK), but this rule lets the owner write
    // directly under the same constraints.
    match /avatars/{uid}/{allAvatarPaths=**} {
      allow read: if false;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType in [
                        'image/jpeg',
                        'image/png',
                        'image/webp'
                      ];
    }

    // Catch-all: deny everything not explicitly allowed above.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

# Backend env vars — Express. Copy this file to `.env` and fill in.
# `.env` is gitignored — never commit real values.

# Express
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# Require a verified email before content-write paths (/api/requests, /api/chats).
# OFF by default so a freshly-registered (unverified) account can still submit
# during local dev and the live demo. Set to "true" in PRODUCTION to enforce it.
# ENFORCE_EMAIL_VERIFICATION=true

# Firebase Admin SDK — point at your local service-account JSON.
# Get the JSON from Firebase console → Settings → Service accounts → Generate new private key.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Firebase project + Storage bucket (audit Prompt 6: these are read by the code
# but were undocumented here). On the deployed Cloud Function these come from the
# platform; set them for local dev / non-default projects.
# FIREBASE_PROJECT_ID=push-for-fulfillment-staging
# FIREBASE_STORAGE_BUCKET=push-for-fulfillment-staging.appspot.com

# CORS: extra comma-separated origins allowed to call the API (FRONTEND_ORIGIN +
# localhost + the project's *.web.app/*.firebaseapp.com are always allowed).
# CORS_ALLOWED_ORIGINS=https://example.com,https://staging.example.com

# Email notifications (SendGrid, req 27). Without SENDGRID_API_KEY the backend
# logs notifications instead of sending (NOTIFY_DEBUG=1 forces verbose logging).
# SENDGRID_API_KEY=
# NOTIFY_FROM_EMAIL=noreply@pff.example
# NOTIFY_REPLY_TO=support@pff.example
# NOTIFY_DEBUG=1

# Optional: Firestore emulator host (only set for local dev with `firebase emulators:start`).
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

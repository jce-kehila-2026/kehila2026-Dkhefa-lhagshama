# Backend env vars — Express. Copy this file to `.env` and fill in.
# `.env` is gitignored — never commit real values.

# Express
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# Require a verified email before content-write paths (/api/requests, /api/chats).
# OFF by default so a freshly-registered (unverified) account can still submit
# during local dev and the live demo. Set to "true" in PRODUCTION to enforce it.
# ENFORCE_EMAIL_VERIFICATION=true

# Firebase Admin SDK — point at your local service-account JSON.
# Get the JSON from Firebase console → Settings → Service accounts → Generate new private key.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Optional: Firestore emulator host (only set for local dev with `firebase emulators:start`).
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

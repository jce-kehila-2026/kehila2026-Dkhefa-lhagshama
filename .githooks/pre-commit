#!/usr/bin/env bash
# Shared pre-commit quality gate. Enabled via: git config core.hooksPath .githooks
# (the root `npm run prepare` script does this automatically).
# Bypass once with: git commit --no-verify
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
staged="$(git diff --cached --name-only --diff-filter=ACM)"

run() { echo "  → $*"; ( "$@" ); }

# Only run the relevant gate for the area that changed — keeps commits fast.
if echo "$staged" | grep -q '^frontend/'; then
  echo "[pre-commit] frontend changed — typecheck"
  # NOTE: `npm run lint` (next lint) is broken under Next 16 — `next lint` was
  # removed and treats "lint" as a project dir. tsc is the meaningful gate here;
  # re-add an eslint call once the lint script is migrated to the ESLint CLI.
  ( cd "$repo_root/frontend" && run npx tsc --noEmit )
fi

if echo "$staged" | grep -q '^backend/'; then
  echo "[pre-commit] backend changed — typecheck"
  ( cd "$repo_root/backend" && run npm run -s type-check )
fi

echo "[pre-commit] OK"
